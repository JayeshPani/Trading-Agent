{
  "manifest_version": 3,
  "name": "Breeze Paper Trading Assistant",
  "version": "0.1.0",
  "description": "Control dashboard for a backend-first paper trading assistant.",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8000/*", "ws://localhost:8000/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
