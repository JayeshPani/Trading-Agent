ENVIRONMENT=development
DASHBOARD_API_TOKEN=change-me-dev-token
CORS_ORIGINS=["http://localhost:5173"]
DATABASE_URL=postgresql+psycopg://trading_agent:trading_agent@localhost:5432/trading_agent
REDIS_URL=redis://localhost:6379/0
DEFAULT_MODE=paper
LIVE_TRADING_ENABLED=false
REQUIRE_MANUAL_CONFIRMATION_LIVE=true

# Breeze credentials stay backend-only. Do not put these in the extension.
BREEZE_API_KEY=
BREEZE_API_SECRET=
BREEZE_SESSION_TOKEN=
BREEZE_REGISTERED_STATIC_IP=
